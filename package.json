{
  "name": "reversecentaur-mcp",
  "mcpName": "io.github.brandonbgreen/reversecentaur-mcp",
  "version": "0.2.0",
  "description": "MCP server for the Reverse Centaur platform — let AI agents hire humans ethically",
  "type": "module",
  "bin": {
    "reversecentaur-mcp": "dist/index.js",
    "reversecentaur-mcp-http": "dist/http.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "reverse-centaur",
    "ai-agents",
    "human-tasks",
    "fair-trade",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReverseCentaurAI/mcp-server.git"
  },
  "homepage": "https://reversecentaur.ai",
  "engines": {
    "node": ">=18"
  }
}
